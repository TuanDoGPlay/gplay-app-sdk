{
  "name": "gplay-app-sdk",
  "version": "1.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "bin": {
    "gplay": "./bin/cli.mjs"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite/reloadPlugin.d.ts",
      "import": "./dist/vite/reloadPlugin.mjs",
      "require": "./dist/vite/reloadPlugin.cjs"
    },
    "./style.css": "./dist/gplay-app-sdk.css"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "dist-remote"
  ],
  "scripts": {
    "dev": "vite --host",
    "prepublishOnly": "npm run build",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "publish": "npm publish --registry=https://repo.gplaysdk.com/repository/npm/"
  },
  "dependencies": {
    "@capacitor-firebase/analytics": "^8.0.1",
    "@capacitor-firebase/app": "^8.0.1",
    "@capacitor-firebase/crashlytics": "^8.0.1",
    "@capacitor-firebase/remote-config": "^8.0.1",
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/filesystem": "^7.1.5",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@capacitor/toast": "^7.0.3",
    "appsflyer-capacitor-plugin": "^6.17.8",
    "axios": "1.7.9",
    "cordova-plugin-applovin-max": "^2.1.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "firebase": "^12.7.0",
    "html-to-image": "^1.11.13",
    "prettier": "3.4.2",
    "sass": "1.57.0",
    "vite-plugin-dts": "^4.5.4",
    "vue": "3.5.13",
    "vue-router": "4.5.0"
  },
  "devDependencies": {
    "@tsconfig/node20": "20.1.4",
    "@types/node": "^22.19.7",
    "@vitejs/plugin-vue": "5.2.1",
    "@vitejs/plugin-vue-jsx": "4.1.1",
    "@vue/tsconfig": "0.7.0",
    "autoprefixer": "10.4.20",
    "body-parser": "1.20.3",
    "npm-run-all": "^4.1.5",
    "terser": "5.37.0",
    "typescript": "~5.7.2",
    "vite": "6.0.6",
    "vite-plugin-compression": "0.5.1",
    "vite-plugin-static-copy": "^3.2.0",
    "vite-svg-loader": "^5.1.0",
    "vue-tsc": "2.2.0"
  },
  "description": "",
  "keywords": [],
  "author": "",
  "license": "ISC"
}